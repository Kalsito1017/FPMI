generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  STUDENT
  TEACHER
  MODERATOR
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(GUEST)
  avatar       String?
  specialty    String?
  hobbies      String?
  createdAt    DateTime @default(now())

  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityLikes    CommunityLike[]
  contactMessages   ContactMessage[]
  refreshTokens     RefreshToken[]
  wikiPages         WikiPage[]
  resources         Resource[]
  exams             Exam[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model CommunityPost {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String?
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments CommunityComment[]
  likes    CommunityLike[]

  @@index([authorId])
  @@index([createdAt])
}

model CommunityComment {
  id              Int                @id @default(autoincrement())
  content         String
  postId          Int
  post            CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentCommentId Int?
  parentComment   CommunityComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         CommunityComment[] @relation("CommentReplies")
  authorId        Int
  author          User               @relation(fields: [authorId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
}

model CommunityLike {
  id        Int           @id @default(autoincrement())
  postId    Int
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model Course {
  id          Int     @id @default(autoincrement())
  title       String
  slug        String  @unique
  description String?
  semester    Int?
  credits     Int?
  category    String

  wikiPages WikiPage[]
  resources Resource[]
  exams     Exam[]
}

enum WikiPageStatus {
  DRAFT
  PUBLISHED
}

model WikiPage {
  id          Int            @id @default(autoincrement())
  courseId    Int
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  content     String
  status      WikiPageStatus @default(PUBLISHED)
  createdById Int
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([courseId, slug])
  @@index([courseId])
  @@index([status])
  @@index([createdById])
}

enum ResourceType {
  LINK
  VIDEO
  DOCUMENT
  BOOK
  OTHER
}

model Resource {
  id          Int          @id @default(autoincrement())
  courseId    Int
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  type        ResourceType @default(LINK)
  url         String
  createdById Int
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([courseId])
  @@index([createdById])
}

model Exam {
  id          Int      @id @default(autoincrement())
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  year        Int
  semester    Int?
  pdfUrl      String
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([courseId])
  @@index([year])
  @@index([createdById])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([used])
  @@index([expiresAt])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String?
  source      String
  sourceUrl   String?
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([publishedAt])
}

enum ContactMessageType {
  SUGGESTION
  FEATURE_REQUEST
  BUG_REPORT
  SPAM
  OTHER
}

enum ContactMessageStatus {
  OPEN
  READ
  RESOLVED
}

model ContactMessage {
  id        Int                  @id @default(autoincrement())
  type      ContactMessageType
  subject   String
  message   String
  userId    Int?
  user      User?                @relation(fields: [userId], references: [id])
  status    ContactMessageStatus @default(OPEN)
  createdAt DateTime             @default(now())

  @@index([status])
  @@index([userId])
}
